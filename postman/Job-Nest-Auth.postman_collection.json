{
  "info": {
    "name": "Job Nest — Auth",
    "_postman_id": "job-nest-auth-v1",
    "description": "Full Auth module for Job Nest Laravel 12 API (Flutter backend).\n\nSet the `base_url` environment variable to your server URL (e.g. http://localhost:8000).\nAfter login or register step 1 the `token` variable is auto-set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Step 1 — Person",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_type\": \"person\",\n  \"name\": \"Ahmed Ali\",\n  \"email\": \"ahmed@example.com\",\n  \"phone\": \"01012345678\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"university\": \"Cairo University\",\n  \"major\": \"Computer Science\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/step-1",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", "step-1"]
            }
          },
          "response": []
        },
        {
          "name": "Register Step 1 — Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_type\": \"company\",\n  \"name\": \"Tech Corp HR\",\n  \"email\": \"hr@techcorp.com\",\n  \"phone\": \"01098765432\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"company_name\": \"Tech Corp\",\n  \"website\": \"https://techcorp.com\",\n  \"company_size\": \"50-100\",\n  \"industry\": \"Technology\",\n  \"location\": \"Cairo, Egypt\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/step-1",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", "step-1"]
            }
          },
          "response": []
        },
        {
          "name": "Register Step 2 — Person",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employment_status\": \"employed\",\n  \"employment_type\": \"full_time\",\n  \"current_job_title\": \"Frontend Developer\",\n  \"company_name\": \"Current Employer Ltd\",\n  \"preferred_work_location\": \"hybrid\",\n  \"expected_salary_min\": 5000,\n  \"expected_salary_max\": 10000,\n  \"linkedin_url\": \"https://linkedin.com/in/ahmed-ali\",\n  \"portfolio_url\": \"https://ahmed.dev\",\n  \"skills\": [1, 2, 3],\n  \"languages\": [1, 2]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/step-2",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", "step-2"]
            }
          },
          "response": []
        },
        {
          "name": "Register Step 2 — Company",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"website\": \"https://techcorp.com\",\n  \"company_size\": \"201-500\",\n  \"industry\": \"Software\",\n  \"location\": \"Cairo, Egypt\",\n  \"about\": \"We build innovative software solutions.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/step-2",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", "step-2"]
            }
          },
          "response": []
        },
        {
          "name": "Register Step 3 — Person",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "about",          "value": "Passionate developer with 3+ years experience.", "type": "text" },
                { "key": "interests[]",    "value": "1",  "type": "text" },
                { "key": "interests[]",    "value": "3",  "type": "text" },
                { "key": "profile_photo",  "type": "file", "src": "" },
                { "key": "cv",             "type": "file", "src": "" },
                { "key": "certificates[]", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/step-3",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", "step-3"]
            }
          },
          "response": []
        },
        {
          "name": "Register Step 3 — Company",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "about", "value": "We build innovative products.", "type": "text" },
                { "key": "logo",  "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/step-3",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", "step-3"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Password",
      "item": [
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email_or_phone\": \"ahmed@example.com\",\n  \"method\": \"email\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          },
          "response": []
        },
        {
          "name": "Verify Reset OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email_or_phone\": \"ahmed@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-reset-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify-reset-otp"]
            }
          },
          "response": []
