{
  "info": {
    "name": "Job Nest - Auth",
    "_postman_id": "job-nest-auth-v3",
    "description": "JobNest Laravel 13 + Sanctum auth API collection with refresh tokens and email verification.\n\nSet `base_url`, then use person register step-1 or register/company, plus login/google-login requests to populate `token`, `refresh_token`, and session fields automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "access_token_expires_at", "value": "", "type": "string" },
    { "key": "refresh_token_expires_at", "value": "", "type": "string" },
    { "key": "current_token_id", "value": "", "type": "string" },
    { "key": "session_id", "value": "", "type": "string" },
    { "key": "verification_id", "value": "", "type": "string" },
    { "key": "verification_hash", "value": "", "type": "string" },
    { "key": "verification_expires", "value": "", "type": "string" },
    { "key": "verification_signature", "value": "", "type": "string" },
    { "key": "google_id_token", "value": "", "type": "string" },
    { "key": "otp", "value": "123456", "type": "string" }
  ],
  "item": [
    {
      "name": "Registration",
      "item": [
        {
          "name": "Register Step 1 - Person",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) { pm.collectionVariables.set('access_token', json.access_token); pm.collectionVariables.set('token', json.access_token); } else if (json.token) { pm.collectionVariables.set('token', json.token); pm.collectionVariables.set('access_token', json.token); }",
                  "if (json.refresh_token) { pm.collectionVariables.set('refresh_token', json.refresh_token); }",
                  "if (json.access_token_expires_at) { pm.collectionVariables.set('access_token_expires_at', json.access_token_expires_at); }",
                  "if (json.refresh_token_expires_at) { pm.collectionVariables.set('refresh_token_expires_at', json.refresh_token_expires_at); }",
                  "if (json.current_token_id) { pm.collectionVariables.set('current_token_id', json.current_token_id); }",
                  "if (json.current_token_id) { pm.collectionVariables.set('session_id', json.current_token_id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_type\": \"person\",\n  \"name\": \"Ali Hassan\",\n  \"email\": \"ali@example.com\",\n  \"phone\": \"01012345678\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"university\": \"Cairo University\",\n  \"major\": \"Computer Science\",\n  \"device_name\": \"flutter-android\"\n}"
            },
            "url": "{{base_url}}/api/auth/register/step-1"
          },
          "response": []
        },
